{
  "name": "yassh.github.io",
  "version": "0.0.0",
  "dependencies": {
    "lz-string": "^1.4.4",
    "marked": "^4.0.18",
    "three": "^0.150.1",
    "throttle-debounce": "^5.0.0"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "@types/jest": "^28.1.1",
    "@types/lz-string": "^1.3.34",
    "@types/marked": "^4.0.3",
    "@types/three": "^0.150.2",
    "@types/throttle-debounce": "^5.0.0",
    "jest": "^28.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "prettier-plugin-organize-imports": "^2.3.4",
    "ts-jest": "^28.0.5",
    "typescript": "^4.7.3",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "private": true,
  "scripts": {
    "build": "vite build",
    "checkall": "run-p lint test",
    "dev": "vite",
    "fix": "run-p fix:*",
    "fix:html": "prettier 'src/**/*.html' --write",
    "fix:js": "prettier 'src/**/*.{js,ts}' --write",
    "lint": "run-p lint:*",
    "lint:html": "prettier 'src/**/*.html' --check",
    "lint:js": "run-p lint:js:*",
    "lint:js:prettier": "prettier 'src/**/*.{js,ts}' --check",
    "lint:js:tsc": "tsc --noEmit",
    "test": "jest"
  }
}
