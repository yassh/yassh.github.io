{
  "name": "yassh.github.io",
  "version": "0.0.0",
  "dependencies": {
    "lz-string": "^1.5.0",
    "marked": "^18.0.2",
    "three": "^0.184.0",
    "throttle-debounce": "^5.0.2"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@types/jest": "^30.0.0",
    "@types/three": "^0.184.0",
    "@types/throttle-debounce": "^5.0.2",
    "jest": "^30.3.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "private": true,
  "scripts": {
    "build": "vite build",
    "checkall": "run-p lint test",
    "dev": "vite",
    "fix": "run-p fix:*",
    "fix:html": "prettier 'src/**/*.html' --write",
    "fix:js": "prettier 'src/**/*.{js,ts}' --write",
    "lint": "run-p lint:*",
    "lint:html": "prettier 'src/**/*.html' --check",
    "lint:js": "run-p lint:js:*",
    "lint:js:prettier": "prettier 'src/**/*.{js,ts}' --check",
    "lint:js:tsc": "tsc --noEmit",
    "test": "jest"
  }
}
